{
  "name": "talents-landing-page",
  "version": "1.0.0",
  "description": "The static public landing page for Talents.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "audit": "npm audit --audit-level=high",
    "audit:signatures": "npm audit signatures",
    "test": "playwright test",
    "test:update": "playwright test --project=chromium --grep @visual --update-snapshots",
    "check": "npm run audit && npm run audit:signatures && npm run build && npm run test",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.46.0",
    "@fontsource/aileron": "5.3.0",
    "@playwright/test": "1.61.1",
    "vite": "8.1.5",
    "wrangler": "^4.113.0"
  }
}
